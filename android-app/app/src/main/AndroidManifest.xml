<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartCut">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AddClienteActivity"
            android:exported="false"
            android:label="Añadir Cliente"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AgendaActivity"
            android:exported="false"
            android:label="Agenda de Citas"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AddCitaActivity"
            android:exported="false"
            android:label="Nueva Cita"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SeleccionPeluqueroActivity"
            android:exported="false"
            android:label="Seleccionar Peluquero"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".SeleccionServicioActivity"
            android:exported="false"
            android:label="Seleccionar Servicio"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CalendarioActivity"
            android:exported="false"
            android:label="Seleccionar Fecha"
            android:parentActivityName=".MainActivity" />

    </application>

</manifest>